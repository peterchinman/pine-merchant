---
const { post } = Astro.props;
---

<a class="blog-post-card" href={post.url}>
   <span class="blog-post-card__date quiet-voice">{post.formattedDate}</span>
   <span class="blog-post-card__body">
      <span class="blog-post-card__title attention-voice">{post.title}</span>
      {
         post.subtitle && (
            <span class="blog-post-card__description soft-reading-voice">{post.subtitle}</span>
         )
      }
   </span>
</a>

<style>
   .blog-post-card {
      display: grid;
      grid-column: 1 / -1;
      grid-template-columns: subgrid;
      align-items: start;
      color: var(--link);
      text-decoration: none;
   }

   .blog-post-card + .blog-post-card {
      padding-top: 2rem;
   }

   .blog-post-card__date {
      color: var(--ink-muted);
      padding-top: .3rem;
   }

   .blog-post-card__body {
      display: grid;
      gap: 0.35rem;
   }

   .blog-post-card__description {
      color: var(--ink-muted);
   }

   @media (max-width: 700px) {
      /* break out of the shared columns: stack date above body */
      .blog-post-card {
         grid-template-columns: 1fr;
         row-gap: 0.35rem;
      }
   }
</style>
