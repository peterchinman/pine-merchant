---
const { post } = Astro.props;
---

<a class="blog-post-card" href={post.url}>
   <span class="blog-post-card__date quiet-voice">{post.formattedDate}</span>
   <span class="blog-post-card__body">
      <span class="blog-post-card__title attention-voice">{post.title}</span>
      {
         post.description && (
            <span class="blog-post-card__description">{post.description}</span>
         )
      }
   </span>
</a>

<style>
   .blog-post-card {
      display: grid;
      grid-template-columns: minmax(8rem, 0.3fr) 1fr;
      gap: 1rem;
      padding: 1.25rem 0;
      color: var(--link);
      text-decoration: none;
   }

   .blog-post-card__date {
      color: var(--ink-muted);
   }

   .blog-post-card__body {
      display: grid;
      gap: 0.35rem;
   }

   .blog-post-card__description {
      color: var(--ink-muted);
   }

   @media (max-width: 700px) {
      .blog-post-card {
         grid-template-columns: 1fr;
         gap: 0.35rem;
      }
   }
</style>
