---
const { title, href } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag class="project-card" href={href}>
   <span class="project-card__title">{title}</span>
   {
      href && (
         <span class="project-card__arrow" aria-hidden="true">
            →
         </span>
      )
   }
</Tag>

<style>
   .project-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 5rem;
      padding: 1rem 0;
      color: var(--link);
      border-top: 1px solid color-mix(in srgb, var(--ink), transparent 82%);
      text-decoration: none;
   }

   .project-card:hover,
   .project-card:focus-visible {
      color: var(--link);
   }

   .project-card__title {
      font-size: clamp(1.35rem, 4vw, 3rem);
      line-height: 1;
      letter-spacing: -0.04em;
   }

   .project-card__arrow {
      font-size: clamp(1.5rem, 4vw, 3rem);
      line-height: 1;
   }
</style>
