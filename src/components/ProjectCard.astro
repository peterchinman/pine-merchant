---
const { title, href } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag class="project-card" href={href}>
   <span class="project-card__title attention-voice">{title}</span>
   {
      href && (
         <span class="project-card__arrow attention-voice" aria-hidden="true">
            →
         </span>
      )
   }
</Tag>

<style>
   .project-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 5rem;
      padding: 1rem 0;
      color: var(--link);
      text-decoration: none;
   }

   .project-card:hover,
   .project-card:focus-visible {
      color: var(--link);
   }

</style>
