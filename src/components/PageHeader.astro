---
const { label, title, description } = Astro.props;
---

<header class="page-header">
   {label && <p class="page-header__label quiet-voice">{label}</p>}
   {
      description && (
         <p class="page-header__description lead-voice">{description}</p>
      )
   }
</header>

<style>
   .page-header__label {
      margin: 0 0 0.75rem;
      color: var(--ink-muted);
   }

   .page-header__description {
      max-width: 38rem;
      margin: 1.5rem 0 0;
      color: var(--ink-muted);
   }
</style>
