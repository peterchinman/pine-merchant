---
import TimelineText from "../../text/timeline.md";
import LinksText from "../../text/links.md";
---

<section class="section timeline-section" aria-label="About">
      <div class="timeline-section__timeline plain-voice">
         <TimelineText />
      </div>

      <div class="timeline-section__links plain-voice">
         <LinksText />
      </div>
</section>

<style>
   .timeline-section :global(dl) {
      display: grid;
      grid-template-columns: clamp(7rem, 18vw, 10rem) minmax(0, 1fr);
      column-gap: clamp(1rem, 4vw, 2rem);
      row-gap: 1rem;
      align-items: baseline;
      margin: 0;
      color: var(--ink);
   }

   .timeline-section :global(dt),
   .timeline-section :global(dd) {
      margin: 0;
      color: var(--ink);
   }

   .timeline-section :global(dt) {
      grid-column: 1;
   }

   .timeline-section :global(dd) {
      grid-column: 2;
   }

   .timeline-section :global(dd p) {
      margin: 0;
   }

   .timeline-section__links {
      :global(h1) {
        font-family: var(--body-mono);
        font-size: var(--fontSize--1);
        font-weight: 400;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      :global(ul) {
        display: flex;
        gap: 1ch;
        padding-top: .5rem;
      }
   }
</style>
