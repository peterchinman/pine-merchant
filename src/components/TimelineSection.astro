---
import TimelineText from "../../text/timeline.md";
import LinksText from "../../text/links.md";
---

<section class="section timeline-section" aria-label="About">
   <div class="timeline-section__content">
      <div class="timeline-section__timeline definition-list">
         <TimelineText />
      </div>

      <div class="timeline-section__links definition-list">
         <LinksText />
      </div>
   </div>
</section>

<style>
   .timeline-section__content {
      display: grid;
      gap: clamp(2rem, 6vw, 4rem);
   }

   .timeline-section :global(dl) {
      display: grid;
      grid-template-columns: clamp(7rem, 18vw, 10rem) minmax(0, 1fr);
      column-gap: clamp(1rem, 4vw, 2rem);
      row-gap: 1rem;
      align-items: baseline;
      margin: 0;
      color: var(--ink);
   }

   .timeline-section :global(dt),
   .timeline-section :global(dd) {
      margin: 0;
      color: var(--ink);
   }

   .timeline-section :global(dt) {
      grid-column: 1;
   }

   .timeline-section :global(dd) {
      grid-column: 2;
   }

   .timeline-section :global(dd p) {
      margin: 0;
   }

   .timeline-section__links {
      padding-top: clamp(1rem, 3vw, 2rem);
   }

   .timeline-section__links :global(dt) {
      font-family: var(--font-display);
      letter-spacing: 0.02em;
      text-transform: uppercase;
   }

   .timeline-section__links :global(dd p) {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
   }

   @media (max-width: 640px) {
      .timeline-section :global(dl) {
         grid-template-columns: 1fr;
         row-gap: 0.25rem;
      }

      .timeline-section :global(dd) {
         grid-column: 1;
         margin-bottom: 0.75rem;
      }

      .timeline-section__links :global(dd) {
         margin-bottom: 0;
      }
   }
</style>
