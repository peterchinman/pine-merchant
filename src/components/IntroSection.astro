---
import BioText from "../../text/bio.md";
import { withBase } from "../lib/base.js";

const anagramScriptUrl = withBase("scripts/anagram-animator.js");
---

<section class="section intro-section" aria-label="Bio">
   <div class="intro-section__content plain-voice">
      <BioText />
   </div>
</section>

<script type="module" src={anagramScriptUrl}></script>

<style>
   .intro-section :global(p) {
      color: var(--ink-muted);
   }

   .intro-section :global(.bio-name) {
      display: inline-grid;
      position: relative;
      color: var(--ink);
      font-family: var(--font-display);
      font-size: var(--fontSize-3);
      letter-spacing: 0.02em;
      line-height: 1;
      text-transform: uppercase;
      vertical-align: baseline;
      white-space: pre;
      cursor: default;
   }

   .intro-section :global(.bio-name [data-role]) {
      grid-area: 1 / 1;
      white-space: pre;
   }

   .intro-section :global(.bio-name .aa-letter),
   .intro-section :global(.bio-name .aa-space) {
      display: inline-block;
      white-space: pre;
   }
</style>
