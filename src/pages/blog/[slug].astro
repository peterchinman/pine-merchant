---
import BaseLayout from "../../layouts/BaseLayout.astro";

import { blogPosts } from "../../lib/blog.js";
import { withBase } from "../../lib/base.js";

export function getStaticPaths() {
   return blogPosts.map((post) => ({
      params: { slug: post.slug },
      props: { post },
   }));
}

const { post } = Astro.props;
const Content = post.Content;
const blogUrl = withBase("blog/");
---

<BaseLayout
   title={`${post.title} · Pine Merchant`}
   description={post.description}
   crumbs={[{ label: "blog", href: blogUrl, anagram: "GLOB" }, post.slug]}
   back={blogUrl}
>
   <main class="scrollable">
      <article class="blog-post section">
         <header class="blog-post__header">
            <p class="blog-post__date quiet-voice">{post.formattedDate}</p>
            <h1 class="title-voice">{post.title}</h1>
            {
               post.subtitle && (
                  <p class="blog-post__subtitle">{post.subtitle}</p>
               )
            }
            {
               post.description && (
                  <p class="blog-post__description plain-voice">
                     {post.description}
                  </p>
               )
            }
         </header>

         <div class="blog-post__content prose">
            <Content />
         </div>
      </article>
   </main>
</BaseLayout>

<script>
   import { killOrphans } from "../../scripts/orphan-killer.js";
   import { initSidenotes } from "../../scripts/sidenotes.js";

   // De-orphan first so sidenotes capture footnote refs from the final DOM.
   killOrphans();
   initSidenotes();
</script>

<style>
   .blog-post__back {
      display: inline-block;
      justify-self: start;
      color: var(--link);
      text-decoration: none;
   }

   .blog-post__back:hover,
   .blog-post__back:focus-visible {
      color: var(--ink);
      text-decoration: underline;
   }

   .blog-post__date {
      margin: 0 0 0.75rem;
      color: var(--ink-muted);
   }

   .blog-post__subtitle {
      margin: 1.25rem 0 0;
      color: var(--ink-muted);
      font-family: var(--font-sans);
      font-style: italic;
      font-size: var(--fontSize-1);
   }

   .blog-post__description {
      margin: 1.5rem 0 0;
      color: var(--ink-muted);
   }

   .blog-post__content {
      position: relative;
   }

   .blog-post__content :global(*) {
      max-width: 100%;
   }

   .blog-post__content :global(p),
   .blog-post__content :global(li) {
      color: var(--ink-muted);
   }

   .blog-post__content :global(h2) {
      margin-top: 2.5rem;
   }

   /* Footnotes-as-sidenotes (built by sidenotes.js). Laid out as
      [number | text]. Narrow: hidden by default, revealed on tap. */
   .blog-post__content :global(.footnote-container) {
      display: none;
      grid-template-columns: auto 1fr;
      column-gap: 0.6rem;
      align-items: baseline;
      margin: 0.75rem 0 1.5rem;
      color: var(--ink-muted);
      font-family: var(--prose);
      font-size: var(--fontSize--1);
      line-height: var(--globalLineHeight);
   }

   .blog-post__content :global(.footnote-container.is-open) {
      display: grid;
   }

   /* the footnote number, in the left column */
   .blog-post__content :global(.footnote-container)::before {
      content: attr(data-index);
      color: var(--ink);
      font-variant-numeric: tabular-nums;
   }

   .blog-post__content :global(.footnote-container p) {
      margin: 0;
   }

   /* Wide: always shown, pulled into the right margin (top set by
      sidenotes.js). Keep this breakpoint in sync with WIDE in sidenotes.js. */
   @media (min-width: 1300px) {
      .blog-post__content :global(.footnote-container) {
         display: grid;
         position: absolute;
         left: 100%;
         width: 16rem;
         margin: 0 0 0 2.5rem;
      }
   }
</style>
