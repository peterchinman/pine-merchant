---
import NavigationBar from "../components/NavigationBar.astro";
import "../styles/global.css";

const {
   title = "Pine Merchant",
   description = "Pine Merchant makes software in New York City.",
} = Astro.props;

const homeUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
   <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <meta name="description" content={description} />
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
         href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400..700&family=Tiny5&display=swap"
         rel="stylesheet"
      />
      <title>{title}</title>
   </head>
   <body>
      <header class="site-header">
         <a class="home-link" href={homeUrl}>PINE MERCHANT</a>
         <NavigationBar />
      </header>

      <slot />
   </body>
</html>

<style is:global>
   .site-header {
      position: fixed;
      top: 1rem;
      left: clamp(1.25rem, 6vw, 5rem);
      z-index: 20;
      display: flex;
      flex-wrap: nowrap;
      align-items: baseline;
      gap: clamp(1rem, 3vw, 1.5rem);
      white-space: nowrap;
   }

   .home-link {
      color: var(--link);
      font-family: var(--font-display);
      font-size: clamp(1rem, 2vw, 1.25rem);
      line-height: 1;
      letter-spacing: 0.02em;
      text-decoration: none;
      text-transform: uppercase;
   }

   .home-link:hover,
   .home-link:focus-visible {
      text-decoration: underline;
   }
</style>
